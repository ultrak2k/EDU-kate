MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 777843715}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4a239f27865894498152ff3059fc296, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueManager
  _parallax: {fileID: 504752828}
  _levelToSpawn: {fileID: 0}
  lines:
  - text: "Kate & EDU are going back to her old lab in an attempt to replace EDU\u2019s
      imploding battery."
    speaker: 0
  - text: ' Kate, already at the school''s gates, calls EDU remotely.'
    speaker: 0
  - text: Hi Kate! Scan Complete. Experimental energy source not detected.
    speaker: 1
  - text: Scan Again. This huge forest must be corrupting your signal.
    speaker: 2
  - text: "We are headed to - 27.1127\xB0 S, 109.3497\xB0 W -"
    speaker: 1
  - text: Thimblewood Middle School.
    speaker: 1
  - text: Please get here fast, I'm worried about you E.D.U
    speaker: 2
  - text: Goodbye Kate!
    speaker: 1
  - text: One More thing.. Remember our training.
    speaker: 2
  - text: (Blue = Good. Purple = Bad.)
    speaker: 0
  speakerNameText: {fileID: 359480074723187480}
  dialogueBodyText: {fileID: 8906236971201518438}
  dialogueBodyTextObject: {fileID: 6827410076623598257}
  dialoguePanel: {fileID: 3826376956514267165}
  NextSceneButton: {fileID: 0}
